# =============================================================================
# SmartERP Environment Configuration
# =============================================================================
# Copy this file to .env and update the values for your environment.
# NEVER commit the .env file to version control.

# -----------------------------------------------------------------------------
# Django Settings
# -----------------------------------------------------------------------------
DJANGO_SECRET_KEY=change-me-to-a-long-random-string-in-production
DJANGO_SETTINGS_MODULE=config.settings.development
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
POSTGRES_DB=smarterp
POSTGRES_USER=smarterp_user
POSTGRES_PASSWORD=smarterp_pass
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgres://smarterp_user:smarterp_pass@db:5432/smarterp

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_PASSWORD=smarterp_redis
REDIS_URL=redis://:smarterp_redis@redis:6379/0
CELERY_BROKER_URL=redis://:smarterp_redis@redis:6379/1
CELERY_RESULT_BACKEND=redis://:smarterp_redis@redis:6379/2

# -----------------------------------------------------------------------------
# Celery
# -----------------------------------------------------------------------------
CELERY_TASK_ALWAYS_EAGER=False
CELERY_WORKER_CONCURRENCY=4

# -----------------------------------------------------------------------------
# Email (SMTP)
# -----------------------------------------------------------------------------
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@smarterp.com

# -----------------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------------
REACT_APP_API_URL=http://localhost/api

# -----------------------------------------------------------------------------
# Nginx
# -----------------------------------------------------------------------------
NGINX_PORT=80
NGINX_SSL_PORT=443

# -----------------------------------------------------------------------------
# JWT Settings
# -----------------------------------------------------------------------------
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# -----------------------------------------------------------------------------
# File Upload
# -----------------------------------------------------------------------------
MAX_UPLOAD_SIZE_MB=10
MEDIA_ROOT=/app/media

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FILE=/app/logs/smarterp.log

# -----------------------------------------------------------------------------
# Sentry (Error Tracking - Production)
# -----------------------------------------------------------------------------
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
